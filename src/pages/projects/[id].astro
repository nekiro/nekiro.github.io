---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const posts = await getCollection("projects");
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { title, summary, tags, cover, ogImage, url } = post.data;

const { Content } = await render(post);
---

<Layout title={title} description={summary} imageOg={ogImage} scrollSmooth={true}>
	<div class="flex flex-col gap-8">
		<div>
			<a href="/" class="text-[10px] uppercase tracking-widest text-muted hover:text-primary transition-none mb-4 inline-block">← Back</a>
			<h1 class="text-base font-bold text-fg uppercase tracking-wide">{title}</h1>
			<div class="flex items-center gap-1.5 mt-2 flex-wrap">
				{tags.map((tag) => (
					<span class="text-[10px] px-1.5 py-0.5 border border-[#333] text-muted">{tag}</span>
				))}
			</div>
		</div>

		<Image
			transition:name={`${post.id}-image`}
			class="w-full object-cover max-h-64 border border-[#222]"
			src={cover}
			alt={"Cover image for " + title}
		/>

		<p class="text-sm text-muted border-l-2 border-[#333] pl-4">{summary}</p>

		{url && (
			<a
				href={url}
				target="_blank"
				class="inline-flex items-center gap-1.5 text-xs text-primary hover:text-primary-hover transition-none uppercase tracking-widest w-fit"
			>
				Visit project ↗
			</a>
		)}

		<div class="border-t border-[#222] pt-8">
			<article class="prose prose-sm max-w-none">
				<Content />
			</article>
		</div>
	</div>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import ProjectList from "@/components/ProjectList.astro";
---

<Layout title="Marcin Jałocha | Projects" description="All my projects" scrollSmooth={false}>
	<div class="flex flex-col gap-8">
		<div>
			<a href="/" class="italic text-sm text-subtle hover:text-primary transition-none mb-6 inline-block">← Back</a>
			<h1 class="text-3xl font-serif text-fg">Projects</h1>
			<p class="text-sm text-muted mt-1">Things I've built over the years.</p>
		</div>
		<ProjectList />
	</div>
</Layout>

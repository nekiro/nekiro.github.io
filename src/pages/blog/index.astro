---
import Layout from "../../layouts/Layout.astro";
import BlogSection from "@/components/BlogSection.astro";
---

<Layout title="Marcin Jałocha | Blog" description="Blog posts" scrollSmooth={false}>
	<div class="flex flex-col gap-8">
		<div>
			<a href="/" class="italic text-sm text-subtle hover:text-primary transition-none mb-6 inline-block">← Back</a>
			<h1 class="text-3xl font-serif text-fg">Blog</h1>
			<p class="text-sm text-muted mt-1">Thoughts and writeups.</p>
		</div>
		<BlogSection />
	</div>
</Layout>

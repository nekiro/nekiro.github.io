---
import { menu } from "../data/menu";
import { SITE } from "../config";

const pathname = Astro.url.pathname;
---

<nav class="fixed w-full z-20 top-0 start-0 border-b border-[#222] bg-bg">
	<div class="container flex items-center justify-between h-12">
		<a href="/" class="text-primary font-bold tracking-tight hover:text-primary-hover transition-none uppercase text-sm">
			{SITE.title}
		</a>
		<div class="flex items-center gap-6">
			{
				menu.map((item) => (
					<a
						href={item.href}
						class:list={{
							["text-xs uppercase tracking-widest transition-none"]: true,
							["text-primary"]: pathname === item.href,
							["text-muted hover:text-fg"]: pathname !== item.href,
						}}
					>
						{item.label}
					</a>
				))
			}
		</div>
	</div>
</nav>

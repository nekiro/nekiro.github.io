---
const skills = [
	"TypeScript", "JavaScript", "Node.js", "React", "Next.js",
	"NestJS", "Express", "Prisma", "MySQL", "Jest",
	"C++", "Lua", "Git", "GitHub Actions", "HTML", "Electron",
];
---

<section>
	<h2 class="text-2xl font-serif text-fg mb-3">Skills</h2>
	<div class="flex flex-wrap gap-1.5">
		{
			skills.map((skill) => (
				<span class="font-mono text-[11px] px-2.5 py-1 border border-dashed border-muted bg-highlight/50 text-subtle cursor-default">
					{skill}
				</span>
			))
		}
	</div>
</section>
